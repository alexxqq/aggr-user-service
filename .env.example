# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
# Use 127.0.0.1 (not localhost) when running Postgres in Docker on macOS to avoid IPv6 connecting to local Postgres
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5433/user_service_db

# Firebase (for ID token verification)
# Download JSON from Firebase Console → Project settings → Service accounts → Generate new private key
# Save it locally (e.g. firebase-service-account.json) — never commit that file
# Run uvicorn from user-service/ if using a relative path
FIREBASE_CREDENTIALS_PATH=
# Or:
# GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json

# Internal API (service-to-service)
INTERNAL_API_SECRET=your-internal-service-secret-change-in-production
