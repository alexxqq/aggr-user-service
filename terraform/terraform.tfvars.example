# Rename to terraform.tfvars and fill in your values

aws_region      = "us-east-1"
environment     = "dev"
service_name    = "aggr-user-service"
github_repo     = "alexxqq/aggr-user-service"
ecs_cluster_name = "thesis-cluster"

# ECS Configuration
ecs_task_cpu    = "256"
ecs_task_memory = "512"
ecs_desired_count = 1
container_port  = 8002

# Logging
log_retention_days = 30

# Secrets (populate via CLI or environment variables)
# WARNING: Do NOT commit actual secrets to version control!
# Instead, use one of these approaches:

# Option 1: Environment variables
# export TF_VAR_database_url="postgresql+asyncpg://user:pass@host:5432/db"
# export TF_VAR_firebase_credentials='{"type":"service_account",...}'
# export TF_VAR_internal_api_secret="your-secret-here"

# Option 2: .tfvars file (gitignore this!)
# Create terraform.tfvars (not in git):
# database_url = "postgresql+asyncpg://user:pass@host:5432/db"
# firebase_credentials = "{...}"
# internal_api_secret = "your-secret-here"

# Option 3: Prompt on apply
# terraform apply
# (Terraform will ask for values)
